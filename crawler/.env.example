# Confluence Settings
CONFLUENCE_URL=https://denev6.tistory.com
CONFLUENCE_USERNAME=your_email@example.com
CONFLUENCE_PASSWORD=your_api_token
START_URL=https://denev6.tistory.com

# Crawling Settings
MAX_DEPTH=5
CRAWL_DELAY=1
LOGIN_REQUIRED=false

# Regex to validate URLs to be crawled. Example for tistory: "^https://[a-zA-Z0-9-]+\\.tistory\\.com.*"
ALLOWED_URL_REGEX="^https://denev6\\.tistory\\.com.*"

# Browser to use for crawling (e.g., "chrome", "firefox")
BROWSER=chrome

# Database path
DB_PATH=/Users/jungwoohan/Documents/03.lgcns/20260103_shinhansec_ns/01.rag/db/rag.db

# Log file path for the crawler
LOG_FILE_PATH=/Users/jungwoohan/Documents/03.lgcns/20260103_shinhansec_ns/01.rag/logs/crawler.log
LOG_LEVEL=INFO
