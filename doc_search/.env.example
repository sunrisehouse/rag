# Elasticsearch settings (only used if VECTOR_STORE_PROVIDER is 'elasticsearch')
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_INDEX_NAME=rag_documents

# Authentication - API Key is recommended. If not provided, username/password will be used.
ELASTICSEARCH_API_ID=YOUR_API_ID
ELASTICSEARCH_API_KEY=YOUR_API_KEY
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=YOUR_ELASTICSEARCH_PASSWORD

# Embedding model settings
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL=jhgan/ko-sbert-nli

# Vector Store Provider ("elasticsearch", "mock", etc.)
VECTOR_STORE_PROVIDER=elasticsearch

# LLM Provider ("gemini", "mock", etc.)
LLM_PROVIDER=gemini

# Google Generative AI settings (only used if LLM_PROVIDER is 'gemini')
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Log settings
LOG_FILE_PATH=/Users/jungwoohan/Documents/03.lgcns/20260103_shinhansec_ns/01.rag/logs/doc_search.log
LOG_LEVEL=INFO
